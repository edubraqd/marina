 
SetEnv MP_ACCESS_TOKEN "SEU_ACCESS_TOKEN_PRODUCAO"
SetEnv MP_WEBHOOK_SECRET "SUA_WEBHOOK_SECRET"

 
Options -Indexes
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "no-referrer-when-downgrade"
  # Ajuste a CSP conforme seus assets (CDNs, etc.). Se der conflito, remova/edite.
  Header always set Content-Security-Policy "default-src 'self'; img-src * data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src *"
</IfModule>

 
#php_flag display_errors Off
#php_value log_errors On
#php_value error_log "logs/php_errors.log"

 
<IfModule mod_rewrite.c>
  RewriteEngine On

 
  RewriteRule ^webhook-mp/?$ webhook-mp.php [L,NC]

 
  RewriteCond %{REQUEST_URI} ^/webhook-mp/?$ [NC]
  RewriteCond %{REQUEST_METHOD} !POST
  RewriteRule ^ - [R=405,L]
</IfModule>
