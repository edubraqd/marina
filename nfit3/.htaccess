Options -Indexes
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "no-referrer-when-downgrade"
  # Ajuste a CSP conforme seus assets (CDNs, etc.). Se der conflito, remova/edite.
  Header always set Content-Security-Policy "default-src 'self'; img-src * data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://sdk.mercadopago.com https://http2.mlstatic.com https://connect.facebook.net; frame-src 'self' https://*.mercadolibre.com https://*.mercadopago.com; connect-src *; font-src 'self' data: https://http2.mlstatic.com https://fonts.gstatic.com"
</IfModule>

# Cache e compressão para assets estáticos (melhora carregamento mobile)
<IfModule mod_headers.c>
  <FilesMatch "\.(?:jpg|jpeg|png|gif|webp|svg|css|js|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=604800, stale-while-revalidate=86400"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/javascript "access plus 7 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType font/woff2 "access plus 30 days"
  ExpiresByType font/woff "access plus 30 days"
  ExpiresByType application/font-woff2 "access plus 30 days"
  ExpiresByType application/vnd.ms-fontobject "access plus 30 days"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

 
#php_flag display_errors Off
#php_value log_errors On
#php_value error_log "logs/php_errors.log"

 
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Corrige links antigos que incluem o caminho de servidor na URL pública
  RewriteRule ^home2/edua0932/public_html/(.*)$ /$1 [R=301,L]

  # Responder 405 para requisições não-POST no webhook
  RewriteCond %{REQUEST_URI} ^/webhook-mp/?$ [NC]
  RewriteCond %{REQUEST_METHOD} !POST
  RewriteRule ^ - [R=405,L]

  # Homologação: manter URLs .php (a regra abaixo causava /nfit3/nfit3/... em subpasta)
  # Se quiser voltar com URL sem extensão depois, reative com regra ajustada ao caminho final.
  # RewriteCond %{REQUEST_URI} !^/webhook-mp\.php$ [NC]
  # RewriteCond %{THE_REQUEST} \s/([^.]+)\.php[\s?]
  # RewriteRule ^ %1 [R=301,L,NE]

  # Mapear URLs sem extensão para arquivos .php existentes
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}\.php -f
  RewriteRule ^(.+)$ $1.php [L,QSA]

  RewriteRule ^webhook-mp/?$ webhook-mp.php [L,NC]
</IfModule>
