  <script>



    document.addEventListener('DOMContentLoaded', function () {



      const form = document.querySelector('.contact form');



      const progressBar = document.getElementById('progress-bar');



      const progressLabel = document.getElementById('progress-label');



      const pills = document.querySelectorAll('#progress-pills .pill');



      const steps = Array.from(document.querySelectorAll('.form-step'));



      let currentStep = 0;







      if (!form || !progressBar || !progressLabel) {



        return;



      }







      const fields = Array.from(form.querySelectorAll('[data-progress]'));



      const sectionMap = {};



      fields.forEach(function (f) {



        const section = f.getAttribute('data-progress');



        if (!sectionMap[section]) {



          sectionMap[section] = [];



        }



        if (!sectionMap[section].includes(f.name)) {



          sectionMap[section].push(f.name);



        }



      });



      const sectionKeys = Object.keys(sectionMap);







      function isFilled(name) {



        const group = fields.filter(function (f) { return f.name === name; });



        if (!group.length) return false;



        const type = (group[0].type || '').toLowerCase();



        if (type === 'radio' || type === 'checkbox') {



          return group.some(function (el) { return el.checked; });



        }



        return (group[0].value || '').trim().length > 0;



      }







      function updatePills(filledSections) {



        pills.forEach(function (pill) {



          const key = pill.getAttribute('data-pill');



          pill.classList.toggle('is-done', filledSections.has(key));



        });



      }







      function updateProgress() {



        const filledSections = new Set();



        sectionKeys.forEach(function (section) {



          const names = sectionMap[section] || [];



          const sectionDone = names.some(function (name) { return isFilled(name); });



          if (sectionDone) filledSections.add(section);



        });



        const byFilled = sectionKeys.length ? Math.round((filledSections.size / sectionKeys.length) * 100) : 0;



        const byStep = steps.length ? Math.round(((currentStep + 1) / steps.length) * 100) : 0;



        const percent = Math.max(byFilled, byStep);



        progressBar.style.width = Math.min(100, percent) + '%';



        progressLabel.textContent = percent + '% conclu횄혘횂혘횄혗횂짯do';



        updatePills(filledSections);



      }







      fields.forEach(function (field) {



        const handler = function () { updateProgress(); };



        field.addEventListener('input', handler);



        field.addEventListener('change', handler);



      });







      document.querySelectorAll('.quick-options').forEach(function (group) {



        const targetName = group.getAttribute('data-fill-target');



        const target = targetName ? form.querySelector('[name="' + targetName + '"]') : null;



        if (!target) return;



        group.querySelectorAll('button').forEach(function (btn) {



          btn.addEventListener('click', function () {



            const current = (target.value || '').trim();



            const addition = btn.textContent.trim();



            if (!addition) return;



            target.value = current ? current + '; ' + addition : addition;



            target.dispatchEvent(new Event('input', { bubbles: true }));



          });



        });



      });







      function showStep(index) {



        steps.forEach(function (step, i) {



          step.classList.toggle('is-active', i === index);



        });



        currentStep = Math.min(Math.max(index, 0), steps.length - 1);



        updateProgress();



        window.scrollTo({ top: document.querySelector('.contact').offsetTop - 40, behavior: 'smooth' });



      }







      function clearErrors(stepEl) {



        stepEl.querySelectorAll('.form-group').forEach(function (fg) {



          fg.classList.remove('has-error');



        });



        const box = stepEl.querySelector('[data-step-error]');



        if (box) {



          box.textContent = '';



          box.style.display = 'none';



        }



      }







      function validateStep(stepEl) {



        clearErrors(stepEl);



        const requiredFields = Array.from(stepEl.querySelectorAll('[data-required]'));



        const missing = [];



        const seenNames = new Set();







        requiredFields.forEach(function (field) {



          const name = field.name;



          if (seenNames.has(name)) return;



          seenNames.add(name);



          const group = requiredFields.filter(function (f) { return f.name === name; });



          const type = (group[0].type || '').toLowerCase();



          let filled = false;



          if (type === 'radio' || type === 'checkbox') {



            filled = group.some(function (el) { return el.checked; });



          } else {



            filled = (group[0].value || '').trim().length > 0;



          }



          if (!filled) {



            const label = group[0].getAttribute('data-label') || name;



            missing.push(label);



            group.forEach(function (el) {



              const fg = el.closest('.form-group');



              if (fg) fg.classList.add('has-error');



            });



          }



        });







        if (missing.length) {



          const box = stepEl.querySelector('[data-step-error]');



          if (box) {



            box.innerHTML = 'Complete para avan횄혘횂혘횄혗횂짠ar: ' + missing.join(' 횄혘횂짖횄짖횂혗횂짭횄혗횂짖 ');



            box.style.display = 'block';



          }



          return false;



        }



        return true;



      }







      form.querySelectorAll('[data-next-step]').forEach(function (btn) {



        btn.addEventListener('click', function () {



          const active = steps[currentStep];



          if (validateStep(active)) {



            showStep(currentStep + 1);



          }



        });



      });



      form.querySelectorAll('[data-prev-step]').forEach(function (btn) {



        btn.addEventListener('click', function () {



          showStep(currentStep - 1);



        });



      });







      setTimeout(updateProgress, 150);



    });



  </script>







  <?php include './partials/footer.php'; ?>



  <?php include './partials/script.php'; ?>



</body>



</html>



